FROM pg_settings
WHERE name IN (
    'autoprepare_for_protocol',
    'autoprepare_threshold',
    'autovacuum_analyze_scale_factor',
    'autovacuum_max_workers',
    'autovacuum_naptime',
    'autovacuum_work_mem',
    'bgwriter_delay',
    'bgwriter_lru_maxpages',
    'bgwriter_lru_multiplier',
    'data_directory',
    'datestyle',
    'default_statistics_target',
    'default_text_search_config',
    'default_toast_compression',
    'dynamic_shared_memory_type',
    'effective_cache_size',
    'effective_io_concurrency',
    'generic_plan_fuzz_factor',
    'jit',
    'lc_messages',
    'lc_monetary',
    'lc_numeric',
    'lc_time',
    'listen_addresses',
    'log2_num_lock_partitions',
    'log_connections',
    'log_disconnections',
    'logging_collector',
    'log_lock_waits',
    'log_timezone',
    'maintenance_work_mem',
    'max_connections',
    'max_wal_size',
    'min_wal_size',
    'password_encryption',
    'plan_cache_lru_memsize',
    'port',
    'random_page_cost',
    'shared_buffers',
    'temp_buffers',
    'timezone',
    'track_activity_query_size',
    'vacuum_cost_limit',
    'wal_compression',
    'work_mem'
